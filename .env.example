# App
APP_NAME=nest-forge
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=nest_forge_dev

# Auth
AUTH_PASSWORD_SALT_ROUNDS=10
JWT_SECRET=replace-with-32-plus-character-secret
JWT_REFRESH_SECRET=replace-with-different-32-plus-character-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PREFIX_KEY=nest-forge

# Seed defaults
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=replace-with-strong-password
SEED_SMTP_FROM_NAME=nest-forge
SEED_SMTP_USERNAME=noreply@example.com
SEED_SMTP_PASSWORD=

# S3-compatible file storage
S3_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# OTP and SMS
OTP_MOCK_ENABLED=true
OTP_MOCK_CODE=000000
SMS_MOCK_ENABLED=true
SMS_POH_ENABLED=false
SMS_POH_API_KEY=
SMS_POH_API_SECRET_KEY=
SMS_POH_BASE_API_URL=
SMS_POH_API_BRAND=
SMS_POH_API_SENDER_ID=
