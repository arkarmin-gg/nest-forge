# App
APP_NAME=nest-forge
NODE_ENV=development
PORT=3000
TZ=UTC

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=nest_forge_dev

# Auth
AUTH_PASSWORD_SALT_ROUNDS=10
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=2592000000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PREFIX_KEY=nest-forge

# S3-compatible file storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# SMTP seed defaults
SMTP_FROM_NAME=nest-forge
SMTP_USERNAME=noreply@example.com
SMTP_USER_PASSWORD=

# OTP and SMS
OTP_MOCK_ENABLED=true
OTP_MOCK_CODE=000000
SMS_MOCK_ENABLED=true
SMS_POH_API_KEY=
SMS_POH_API_SECRET_KEY=
SMS_POH_BASE_API_URL=
SMS_POH_API_BRAND=
SMS_POH_API_SENDER_ID=
